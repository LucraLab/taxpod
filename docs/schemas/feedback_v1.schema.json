{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxpod.openclaw.io/schemas/feedback_v1.schema.json",
  "title": "FeedbackV1",
  "description": "CPA feedback on a PORT3 CPA handoff package. Input to PORT4 changeset builder.",
  "type": "object",
  "required": [
    "version",
    "feedback_id",
    "case_id",
    "source",
    "received_utc",
    "package_manifest_sha256",
    "items"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "const": "FeedbackV1"
    },
    "feedback_id": {
      "type": "string",
      "pattern": "^.+_fb_[0-9]{8}T[0-9]{6}Z$",
      "description": "Deterministic ID: <case_id>_fb_<received_utc>"
    },
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "enum": ["CPA", "EA", "ATTORNEY", "INTERNAL_REVIEW"]
    },
    "received_utc": {
      "type": "string",
      "pattern": "^[0-9]{8}T[0-9]{6}Z$",
      "description": "ISO-like UTC timestamp, e.g., 20260222T120000Z"
    },
    "package_manifest_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "SHA-256 hex digest of the reviewed package manifest.json"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/FeedbackItem"
      },
      "description": "At least one feedback item required (empty array is rejected)."
    }
  },
  "$defs": {
    "FeedbackItem": {
      "type": "object",
      "required": [
        "item_id",
        "type",
        "target",
        "proposed_change",
        "evidence",
        "requires_human_approval"
      ],
      "additionalProperties": false,
      "properties": {
        "item_id": {
          "type": "string",
          "pattern": "^item_[0-9]{3}$",
          "description": "Unique within this feedback. Sequential: item_001, item_002, ..."
        },
        "type": {
          "type": "string",
          "enum": [
            "LIABILITY_CORRECTION",
            "MISSING_DOC",
            "DOC_CLASSIFICATION_FIX",
            "PAYMENT_CAPACITY_ASSUMPTION_FIX",
            "STRATEGY_OVERRIDE_NOTE",
            "DISPUTE_OR_UNCERTAIN"
          ]
        },
        "target": {
          "$ref": "#/$defs/FeedbackTarget"
        },
        "proposed_change": {
          "type": "object",
          "description": "Schema depends on type. See type-specific definitions in CPA_FEEDBACK_V1.md.",
          "minProperties": 1
        },
        "evidence": {
          "$ref": "#/$defs/Evidence"
        },
        "requires_human_approval": {
          "type": "boolean",
          "description": "Must be true in V1. All feedback items require human approval."
        }
      }
    },
    "FeedbackTarget": {
      "type": "object",
      "required": ["artifact"],
      "additionalProperties": false,
      "properties": {
        "artifact": {
          "type": "string",
          "enum": [
            "LIABILITY_SNAPSHOT",
            "PAYMENT_MODEL",
            "STRATEGY",
            "PACKAGE"
          ]
        },
        "path": {
          "type": "string",
          "description": "JSONPath-like string, e.g., tax_years[year=2022].interest"
        },
        "year": {
          "type": "integer",
          "minimum": 2000,
          "maximum": 2099,
          "description": "Tax year for year-specific corrections"
        },
        "doc_id": {
          "type": "string",
          "description": "Document identifier for doc-specific feedback"
        }
      }
    },
    "Evidence": {
      "type": "object",
      "required": ["notes", "attachments", "confidence"],
      "additionalProperties": false,
      "properties": {
        "notes": {
          "type": "string",
          "minLength": 1,
          "description": "CPA explanation of the issue"
        },
        "attachments": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Filenames or doc IDs. No raw blobs."
        },
        "confidence": {
          "type": "string",
          "enum": ["HIGH", "MED", "LOW"]
        }
      }
    }
  }
}
